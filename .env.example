# Yearns — Environment variables example
# Copy to .env.local and fill in real values.
# Never commit .env.local — it is in .gitignore.
# For Vercel: set these via dashboard or `vercel env add`.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never NEXT_PUBLIC_

# ─── Anthropic (levels 1-2: suggestive + sensual) ────────────────────────────
# IMPORTANT: Apply for adult content operator access before using in production.
# https://docs.anthropic.com/en/docs/about-claude/policies
ANTHROPIC_API_KEY=sk-ant-...

# ─── Together.ai (levels 3-4: explicit + unrestricted) ───────────────────────
# Used for explicitness levels 3 and 4. No content restrictions on these models.
# Models: Llama 3.1 70B Instruct Turbo (level 3), Mixtral 8x22B (level 4)
# https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# ─── Stripe (primary payment processor) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...           # sk_test_ for development
STRIPE_WEBHOOK_SECRET=whsec_...         # from Stripe dashboard → Webhooks
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# ─── CCBill (adult content backup processor — set up immediately) ─────────────
# Do NOT skip. If Stripe drops the account, CCBill must be ready.
# https://www.ccbill.com/
CCBILL_ACCOUNT_NUMBER=            # 6-digit account number from CCBill
CCBILL_SUB_ACCOUNT_NUMBER=        # 4-digit sub-account number
CCBILL_FLEXFORM_ID=               # FlexForm ID from CCBill dashboard → FlexForms
CCBILL_DATALINK_USERNAME=         # for DataLink subscription management API
CCBILL_DATALINK_PASSWORD=
CCBILL_WEBHOOK_SECRET=            # account salt — used for price hashes AND postback verification

# ─── Veriff (age verification — UK Online Safety Act compliance) ──────────────
# https://veriff.com/
VERIFF_API_KEY=
VERIFF_SECRET=
VERIFF_BASE_URL=https://stationapi.veriff.com   # use sandbox URL for dev

# ─── Upstash Redis (rate limiting — edge compatible) ─────────────────────────
# Create at https://upstash.com/ → Redis → Create Database
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Email (Resend — transactional only) ──────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@yearns.app

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000         # https://yearns.app in prod
NEXT_PUBLIC_APP_NAME=Yearns

# ─── Sentry (error tracking) ─────────────────────────────────────────────────
# Configure to scrub PII from payloads before sending.
SENTRY_DSN=https://...sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...sentry.io/...
SENTRY_AUTH_TOKEN=            # for source map uploads — generate at sentry.io → Settings → Auth Tokens
SENTRY_ORG=                   # your Sentry organisation slug
SENTRY_PROJECT=yearns         # your Sentry project slug

# ─── Plausible (privacy-first analytics) ─────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yearns.app
